{
  "name": "@lage-run/lage-monorepo",
  "private": true,
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/lage"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts"
    ]
  },
  "scripts": {
    "api": "yarn lage api",
    "build": "lage transpile types build bundle api",
    "watch": "lage transpile isolatedTypes --no-cache --verbose --unstable-watch",
    "change": "beachball change",
    "checkchange": "beachball check",
    "ci": "lage transpile types build test lint bundle api",
    "release": "beachball publish -y --tag latest",
    "test": "lage test --verbose",
    "lage-local": "node packages/lage/dist/lage.js",
    "lint": "lage lint",
    "deps:check": "lage depcheck",
    "decks:build": "npm exec --package=@marp-team/marp-cli -- marp -I decks --pdf -o decks/dist",
    "docs": "yarn --cwd docs start",
    "docs:install": "yarn --cwd docs",
    "docs:build": "yarn --cwd docs build",
    "docs:test": "yarn --cwd docs build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "syncpack:check": "syncpack list-mismatches",
    "syncpack:update": "syncpack fix-mismatches",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@types/node": "^16.18.3",
    "beachball": "2.64.3",
    "dts-bundle-generator": "patch:dts-bundle-generator@npm%3A9.5.1#~/.yarn/patches/dts-bundle-generator-npm-9.5.1-0927b6826f.patch",
    "fast-glob": "3.3.3",
    "husky": "^9.1.5",
    "jest": "^30.0.0",
    "lage-npm": "npm:lage@<2.14.16",
    "lint-staged": "^16.0.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.0.0",
    "syncpack": "^13.0.0",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3"
  },
  "resolutions": {
    "@azure/core-auth": "1.9.0",
    "@azure/core-client": "1.9.4",
    "@azure/core-http-compat": "2.3.0",
    "@azure/core-rest-pipeline": "1.21.0",
    "@azure/core-tracing": "1.2.0",
    "@azure/core-util": "1.12.0",
    "@azure/core-xml": "1.4.5",
    "@azure/logger": "1.2.0",
    "@azure/storage-blob": "12.27.0",
    "@microsoft/api-extractor/lodash@npm:~4.17.15": "^4.18.1",
    "@microsoft/api-extractor/minimatch@npm:~3.0.3": "^3.1.5",
    "@microsoft/api-extractor/typescript": "~5.9.3",
    "@microsoft/tsdoc-config/ajv@npm:~8.12.0": "^8.18.0",
    "@rushstack/node-core-library/ajv@npm:~8.13.0": "^8.18.0",
    "@types/node@npm:*": "^16.0.0",
    "beachball/workspace-tools": "latest",
    "node-gyp@npm:latest": "^9.0.0",
    "listr2@npm:^9.0.5": "9.0.3",
    "syncpack/minimatch@npm:9.0.5": "^9.0.6",
    "tar@npm:^6.1.11": "^7.5.11",
    "tar@npm:^6.1.2": "^7.5.11",
    "dts-bundle-generator/typescript@npm:>=5.0.2": "~5.9.3"
  },
  "rationale": {
    "resolutions": {
      "@azure/*": "Pin to newest versions compatible with Node 18",
      "@microsoft/api-extractor/lodash@npm:~4.17.15": "Unpin from api-extractor to fix security issue",
      "@microsoft/api-extractor/minimatch@npm:~3.0.3": "Unpin from api-extractor to fix security issue",
      "@microsoft/api-extractor/typescript": "Prevent duplicate TS version",
      "@microsoft/tsdoc-config/ajv@npm:~8.12.0": "Update to fix security issue",
      "@rushstack/node-core-library/ajv@npm:~8.13.0": "Update to fix security issue",
      "beachball/workspace-tools": "Reference a different version to avoid issues with local breaking changes",
      "node-gyp@npm:latest": "Stop pulling in other newer deps",
      "listr2@npm:^9.0.5": "Prevent pulling in cli-truncate@5 => string-width@8 which requires Node 20",
      "syncpack/minimatch@npm:9.0.5": "Unpin to fix security issue",
      "tar": "Fix security issue (compatible API)",
      "typescript@npm:>=5.0.2": "Restrict range from dts-bundle-generator to prevent duplicates"
    }
  },
  "lint-staged": {
    "*": "prettier --write"
  },
  "engines": {
    "node": ">=16.14.0"
  }
}
