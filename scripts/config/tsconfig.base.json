{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    // NOTE: This target isn't actually used, since most packages use SWC for emit
    "target": "ES2020",
    "declaration": true,
    "emitDeclarationOnly": true,
    "isolatedModules": true,
    "lib": ["ES2020"],
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "types": ["node"]
  }
}
